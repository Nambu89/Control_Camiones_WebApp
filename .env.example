# ---------------------------------------------------------------------------
# Truck Control Web App — Environment Configuration Example
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env      (Linux/macOS)
#   copy .env.example .env    (Windows)
#
# All variables are optional — the app runs with sensible defaults.
# The application loads this file automatically on startup when present.
# ---------------------------------------------------------------------------

# Path to the SQLite database file.
# Use an absolute path when running in Docker with a mounted volume
# so data persists across container restarts.
# Example (Docker): /app/data/database.db
DATABASE_PATH=database.db

# IANA timezone name used for entry/exit timestamps.
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
APP_TIMEZONE=Europe/Madrid

# Flask debug mode. Set to 1 for development, 0 for production.
# WARNING: never enable debug mode in production.
FLASK_DEBUG=0

# Application log level.
# Recommended values: INFO for MVP, DEBUG only in local development.
LOG_LEVEL=INFO

# Port the application listens on.
# Azure App Service and Heroku set this automatically via PORT.
PORT=5000

# Maximum accepted request size in bytes.
# Default 262144 (256 KB) is sufficient for standard HTML form submissions.
MAX_CONTENT_LENGTH=262144
